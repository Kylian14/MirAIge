# =====================================================================
#  Mir[AI]ge — example environment
#  Copy to `.env` (already git-ignored) and tweak as needed.
#
#  ►  THE STACK RUNS OUT-OF-THE-BOX WITH ZERO CREDENTIALS.
#     `cp .env.example .env && docker compose up --build` just works:
#       · Sentinel runs in heuristic stub mode (no LLM, SENTINEL_STUB=1)
#       · The load-balancer reroute is mocked (REROUTE_BACKEND=mock)
#     Everything below the "CORE" block is OPTIONAL.
# =====================================================================

# ─── CORE · behaviour tuning (no secrets required) ──────────────────
SENTINEL_STUB=1                        # 1 = offline heuristic detection (no LLM). Set 0 to use the LLM tier.
REROUTE_BACKEND=mock                    # mock = LB reroute mocked in-process. Set 'octavia' for a real OpenStack/Octavia LB.
RESOURCE_PREFIX=miraige                 # prefix for cloud resource names (LB, pool, L7 policies) — octavia backend only
SENTINEL_DETECTION_THRESHOLD=0.75      # min LLM confidence to alert (used when SENTINEL_STUB=0)
ATTACK_VELOCITY_RPS_THRESHOLD=20       # req/sec heuristic
HONEYPOT_TTL_SECONDS=1800              # ghost session auto-expire (30 min)
ORCHESTRATOR_STATE_BACKEND=redis       # engagement state: 'memory' (single instance) or 'redis' (crash-safe, shared)
LOG_LEVEL=INFO
PORTAL_HOST_PORT=8090                  # host port for the protected demo portal

# Grid electricity price for the energy/CO2 cost model (mirage_metrics).
# Example below = a typical low-carbon French PPA. Override for your region.
GRID_PRICE_EUR_PER_KWH=0.085

# ─── CORE · internal secrets (fine for local demo, CHANGE for prod) ─
# Defaults are used if unset; services log a warning when a default is in use.
# Production hardening: set MG_STRICT_SECRETS=1 so any default/placeholder secret
# below makes the service HARD-FAIL at startup instead of only warning.
MG_STRICT_SECRETS=0
DASHBOARD_PASSWORD=change-me-dashboard-password    # console gate — SET before any public deploy
# DASHBOARD_TOKEN_SECRET=            # optional: persistent auth-token signing key (else random per restart)
#
# Access control (RBAC) on the console. AUTH_BACKEND=local uses the built-in store:
AUTH_BACKEND=local                     # 'oidc' is a reserved seam (validate an IdP JWT) — not implemented yet
# MIRAIGE_USERS_FILE=                  # path to a users.json (see users.example.json) → viewer/operator/admin roles
#                                      # unset → a single 'admin' synthesized from DASHBOARD_PASSWORD (zero-config)
# MIRAIGE_TOKEN_TTL_S=43200           # bearer-token lifetime in seconds (default 12h)
A2A_SHARED_SECRET=change-me-in-production-please   # HMAC-SHA256 signing between agents
SECRET_SALT=change-me-ghost-shell      # ghost_shell honeytoken salt
# MG_RESET_SECRET=change-me-reset      # optional: token for the /reset demo endpoints

# =====================================================================
#  OPTIONAL · LLM tier T2 (Sentinel) — any OpenAI-compatible endpoint
# =====================================================================
# Leave empty to keep the heuristic stub (SENTINEL_STUB=1).
# Works with OVH AI Endpoints, OpenAI, Together, Groq, a local vLLM/Ollama, etc.
# Set SENTINEL_STUB=0 once these are filled in.
AI_ENDPOINTS_BASE_URL=                 # e.g. https://api.openai.com/v1  ·  or your OVH AI Endpoints /v1 URL
AI_ENDPOINTS_API_KEY=                  # bearer token for the endpoint above
AI_MODEL_CLASSIFIER=Llama-3.1-8B-Instruct   # cheap/fast classifier model (Sentinel T2)
AI_MODEL_GENERATOR=                    # optional: larger model for richer fake honeypot data
# AI_MODEL_EMBEDDING=bge-m3            # optional: embeddings for anomaly detection

# =====================================================================
#  OPTIONAL · real infrastructure reroute (OVH Public Cloud / OpenStack)
#  Only needed when REROUTE_BACKEND=octavia to drive a real Octavia load balancer.
#  Everything works without this via the built-in mock.
# =====================================================================
# OVH API v6 (https://www.ovh.com/auth/api/createToken)
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=
OVH_PROJECT_ID=
# OVH_REGION=GRA11                     # e.g. GRA11 (low-carbon region)

# OpenStack / Octavia (Keystone auth, distinct from the OVH API v6 creds above)
# OS_AUTH_URL=https://auth.cloud.ovh.net/v3
OS_USERNAME=
OS_PASSWORD=
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
# Octavia load-balancer id + ghost pool id (only when REROUTE_BACKEND=octavia):
LB_ID=
GHOST_POOL_ID=

# =====================================================================
#  OPTIONAL · split deployment (services across several VMs)
# =====================================================================
# SENTINEL_URL=http://sentinel:8001
# ORCHESTRATOR_URL=http://orchestrator:8002
# MCP_SERVER_URL=http://mcp_server:8003
# DASHBOARD_URL=http://dashboard:8000
# GHOST_SHELL_URL=http://<ghost-vm-ip>:8080   # ghost_shell on a separate VM
# MIRAGE_METRICS_IP=                          # control-plane VM IP for remote metrics
# LB_TARGET=http://<lb-ip>                    # real LB front IP for dashboard-launched attacks
TARGET_VM_NAME=miraige-portal-prod
HONEYPOT_VM_NAME=miraige-ghost-vm
